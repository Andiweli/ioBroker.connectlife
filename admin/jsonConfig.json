{
  "i18n": true,
  "type": "panel",
  "items": {
    "login": {
      "type": "text",
      "label": "loginLabel",
      "newLine": true,
      "sm": 12,
      "md": 5,
      "lg": 4,
      "xl": 4,
      "style": {
        "maxWidth": "40ch"
      }
    },
    "password": {
      "type": "password",
      "label": "passwordLabel",
      "newLine": true,
      "sm": 12,
      "md": 5,
      "lg": 4,
      "xl": 4,
      "style": {
        "maxWidth": "40ch"
      }
    },
    "pollInterval": {
      "type": "number",
      "label": "pollIntervalLabel",
      "min": 30,
      "max": 3600,
      "step": 10,
      "newLine": true,
      "sm": 12,
      "md": 4
    },
    "createRawStates": {
      "type": "checkbox",
      "label": "createRawStatesLabel",
      "newLine": true
    },
    "allowRawWrites": {
      "type": "checkbox",
      "label": "allowRawWritesLabel",
      "newLine": true
    },
    "_footer": {
      "type": "staticText",
      "format": "html",
      "text": "footerText",
      "newLine": true,
      "sm": 12
    }
  }
}
